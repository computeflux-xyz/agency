---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import PageHero from "@organisms/PageHero.astro";
import CtaSection from "@organisms/CtaSection.astro";
import ArticleCard from "@molecules/ArticleCard.astro";
import Divider from "@atoms/Divider.astro";
import { site } from "@lib/site";

const title = "Case studies";
const description =
  "Deep dives with measured outcomes — anonymized case studies on inference cost reduction, agent reliability and systems-level performance.";

const studies = (await getCollection("studies", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const topics = Array.from(
  new Set(studies.flatMap((s) => s.data.topics)),
).sort();

const origin = Astro.site?.origin ?? site.url;
const jsonLd = {
  "@type": "CollectionPage",
  name: `${title} — ${site.name}`,
  description,
  url: `${origin}/studies`,
  isPartOf: { "@id": `${site.url}/#website` },
};
---

<PageLayout title={title} description={description} jsonLd={jsonLd} dragon>
  <PageHero
    eyebrow="Selected work"
    title="Case studies"
    lead={description}
  />

  <section class="container-flux pb-24">
    <Divider label={`${studies.length} STUDIES`} />

    <div class="flex flex-wrap gap-2 py-8" data-study-filters>
      <button
        type="button"
        data-topic="all"
        aria-pressed="true"
        class="rounded-[var(--radius-sm)] border px-3.5 py-1.5 font-mono text-[0.7rem] font-medium uppercase tracking-wider transition-colors data-[active=true]:border-ink-50 data-[active=true]:bg-ink-50 data-[active=true]:text-ink-950 data-[active=false]:border-[var(--color-ink-line)] data-[active=false]:bg-transparent data-[active=false]:text-ink-400"
        data-active="true"
      >
        All
      </button>
      {
        topics.map((t) => (
          <button
            type="button"
            data-topic={t.toLowerCase()}
            aria-pressed="false"
            data-active="false"
            class="rounded-[var(--radius-sm)] border px-3.5 py-1.5 font-mono text-[0.7rem] font-medium uppercase tracking-wider transition-colors hover:text-ink-50 hover:border-ink-50 data-[active=true]:border-ink-50 data-[active=true]:bg-ink-50 data-[active=true]:text-ink-950 data-[active=false]:border-[var(--color-ink-line)] data-[active=false]:bg-transparent data-[active=false]:text-ink-400"
          >
            {t}
          </button>
        ))
      }
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3" data-reveal-stagger="80" data-study-grid>
      {
        studies.map((study) => (
          <div data-topics={study.data.topics.map((t) => t.toLowerCase()).join(",")}>
            <ArticleCard
              href={`/studies/${study.id}`}
              title={study.data.title}
              description={study.data.description}
              kind="study"
              topics={study.data.topics}
              date={study.data.publishDate.toISOString()}
              cover={study.data.cover}
            />
          </div>
        ))
      }
    </div>
  </section>

  <CtaSection />
</PageLayout>

<script>
  function initFilters() {
    const bar = document.querySelector<HTMLElement>("[data-study-filters]");
    const grid = document.querySelector<HTMLElement>("[data-study-grid]");
    if (!bar || !grid) return;

    const items = Array.from(grid.querySelectorAll<HTMLElement>("[data-topics]"));
    const buttons = Array.from(bar.querySelectorAll<HTMLButtonElement>("[data-topic]"));

    const apply = (topic: string) => {
      buttons.forEach((b) => {
        const active = b.dataset.topic === topic;
        b.dataset.active = String(active);
        b.setAttribute("aria-pressed", String(active));
      });
      items.forEach((item) => {
        const topics = (item.dataset.topics ?? "").split(",");
        item.style.display =
          topic === "all" || topics.includes(topic) ? "" : "none";
      });
    };

    buttons.forEach((b) =>
      b.addEventListener("click", () => apply(b.dataset.topic ?? "all")),
    );

    const param = new URLSearchParams(location.search).get("topic");
    if (param) apply(param.toLowerCase());
  }

  initFilters();
  document.addEventListener("astro:after-swap", initFilters);
</script>
