---
import Button from "@atoms/Button.astro";
import Eyebrow from "@atoms/Eyebrow.astro";
import ScrambleText from "@atoms/ScrambleText.astro";
import Icon from "@atoms/Icon.astro";

const rotating = [
  "inference cost.",
  "agent reliability.",
  "systems performance.",
  "production latency.",
];
---

<section class="relative overflow-hidden pt-32 md:pt-40" aria-label="Introduction">
  <div
    class="pointer-events-none absolute left-1/2 top-0 -z-10 h-[42rem] w-[42rem] -translate-x-1/2 -translate-y-1/3 rounded-full bg-flux-blue/[0.07] blur-[120px]"
    aria-hidden="true"
  >
  </div>

  <div class="container-flux flex flex-col items-center gap-8 pb-20 text-center md:pb-28">
    <div data-reveal>
      <Eyebrow accent="blue">Deep tech R&amp;D studio · est. 2026</Eyebrow>
    </div>

    <h1
      class="max-w-4xl text-balance text-[2.6rem] font-semibold leading-[1.02] tracking-tight sm:text-6xl md:text-[4.5rem]"
      data-reveal
    >
      We engineer <span class="flux-gradient-text">high-performance</span>
      <br class="hidden sm:block" />
      AI systems that ship.
    </h1>

    <p class="max-w-2xl text-pretty text-lg leading-relaxed text-ink-300 md:text-xl" data-reveal>
      Computeflux is a research &amp; development studio for teams putting AI into
      production. We cut
      <span
        data-rotator
        data-words={JSON.stringify(rotating)}
        class="font-mono text-ink-100"
        >inference cost.</span
      >
    </p>

    <div class="flex flex-col items-center gap-3 sm:flex-row" data-reveal>
      <Button href="/book" variant="primary" size="lg" arrow>Book a call</Button>
      <Button href="/expertise" variant="outline" size="lg">Explore our expertise</Button>
    </div>

    <div
      class="mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 font-mono text-xs uppercase tracking-[0.18em] text-ink-400"
      data-reveal
    >
      <span class="flex items-center gap-2"><span class="size-1.5 rounded-full bg-flux-blue"></span><ScrambleText text="Inference optimization" /></span>
      <span class="flex items-center gap-2"><span class="size-1.5 rounded-full bg-flux-magenta"></span><ScrambleText text="Agentic systems" delay={120} /></span>
      <span class="flex items-center gap-2"><span class="size-1.5 rounded-full bg-flux-amber"></span><ScrambleText text="Rust · Zig · Go" delay={240} /></span>
    </div>
  </div>

  <div class="flex justify-center pb-8" aria-hidden="true">
    <span class="flex flex-col items-center gap-2 text-ink-500">
      <span class="font-mono text-[0.6rem] uppercase tracking-[0.2em]">Scroll</span>
      <Icon name="chevron" size={16} class="animate-bounce" />
    </span>
  </div>
</section>

<script>
  import { TextScramble } from "@lib/client/scramble";

  function initRotator() {
    const el = document.querySelector<HTMLElement>("[data-rotator]");
    if (!el) return;
    let words: string[] = [];
    try {
      words = JSON.parse(el.dataset.words ?? "[]");
    } catch {
      return;
    }
    if (words.length < 2) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const fx = new TextScramble(el);
    let i = 0;
    const tick = async () => {
      await fx.setText(words[i]);
      i = (i + 1) % words.length;
      window.setTimeout(tick, 2200);
    };
    window.setTimeout(tick, 1600);
  }

  initRotator();
  document.addEventListener("astro:after-swap", initRotator);
</script>
