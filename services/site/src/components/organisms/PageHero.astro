---
import Eyebrow from "@atoms/Eyebrow.astro";

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  accent?: "blue" | "magenta" | "amber" | "muted";
  scramble?: boolean;
  class?: string;
}
const {
  eyebrow,
  title,
  lead,
  accent = "blue",
  scramble = false,
  class: className = "",
} = Astro.props;
---

<section class:list={["relative overflow-hidden pt-32 pb-14 md:pt-40 md:pb-20", className]}>
  <div
    class="pointer-events-none absolute left-1/2 top-0 -z-10 h-80 w-[36rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-flux-blue/[0.06] blur-[110px]"
    aria-hidden="true"
  >
  </div>

  <div class="container-flux flex max-w-3xl flex-col gap-5">
    {eyebrow && <span data-reveal><Eyebrow accent={accent}>{eyebrow}</Eyebrow></span>}
    <h1
      class="text-balance text-4xl font-semibold leading-[1.03] tracking-tight sm:text-5xl md:text-[3.75rem]"
      data-reveal
      {...scramble ? { "data-scramble": "", "data-scramble-on": "load" } : {}}
    >
      {title}
    </h1>
    {
      lead && (
        <p class="max-w-2xl text-pretty text-lg leading-relaxed text-ink-300 md:text-xl" data-reveal>
          {lead}
        </p>
      )
    }
    <slot />
  </div>
</section>
