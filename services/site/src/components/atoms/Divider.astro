---

interface Props {
  label?: string;
  class?: string;
}
const { label, class: className = "" } = Astro.props;
---

<div class:list={["relative flex items-center", className]} role="separator">
  <span class="hairline"></span>
  {
    label && (
      <span class="absolute left-0 -top-2 bg-[var(--color-bg)] pr-4 font-mono text-[0.66rem] font-medium uppercase tracking-[0.16em] text-ink-400">
        {label}
      </span>
    )
  }
</div>
