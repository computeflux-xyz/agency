---
import Eyebrow from "@atoms/Eyebrow.astro";

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: "left" | "center";
  accent?: "blue" | "magenta" | "amber" | "muted";
  class?: string;
}
const {
  eyebrow,
  title,
  lead,
  align = "left",
  accent = "blue",
  class: className = "",
} = Astro.props;
---

<header
  class:list={[
    "flex flex-col gap-4",
    align === "center" ? "items-center text-center max-w-2xl mx-auto" : "max-w-3xl",
    className,
  ]}
  data-reveal
>
  {eyebrow && <Eyebrow accent={accent}>{eyebrow}</Eyebrow>}
  <h2 class="text-balance text-3xl font-semibold leading-[1.05] sm:text-4xl md:text-[2.75rem]">
    {title}
  </h2>
  {
    lead && (
      <p class="max-w-2xl text-pretty text-base leading-relaxed text-ink-300 md:text-lg">
        {lead}
      </p>
    )
  }
</header>
