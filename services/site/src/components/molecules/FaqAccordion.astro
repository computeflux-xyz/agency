---
import Icon from "@atoms/Icon.astro";

interface Props {
  items: { question: string; answer: string }[];
  class?: string;
}
const { items, class: className = "" } = Astro.props;
---

<div class:list={["divide-y divide-[var(--color-border)]", className]}>
  {
    items.map((item) => (
      <details class="group py-1">
        <summary
          class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left"
        >
          <span class="text-base font-medium text-ink-50 md:text-lg">{item.question}</span>
          <span
            class="flex size-8 shrink-0 items-center justify-center rounded-full border border-[var(--color-border)] text-ink-300 transition-all duration-300 group-open:rotate-45 group-open:border-flux-blue group-open:text-flux-blue"
          >
            <Icon name="plus" size={16} />
          </span>
        </summary>
        <div class="overflow-hidden pb-5 pr-12">
          <p class="text-pretty leading-relaxed text-ink-300">{item.answer}</p>
        </div>
      </details>
    ))
  }
</div>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
